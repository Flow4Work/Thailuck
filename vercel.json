{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/",
      "destination": "/release-20260713-0750",
      "permanent": false
    },
    {
      "source": "/app",
      "destination": "/release-20260713-0750",
      "permanent": false
    },
    {
      "source": "/app.html",
      "destination": "/release-20260713-0750",
      "permanent": false
    },
    {
      "source": "/index.html",
      "destination": "/release-20260713-0750",
      "permanent": false
    },
    {
      "source": "/release-20260713-0735",
      "destination": "/release-20260713-0750",
      "permanent": false
    },
    {
      "source": "/release-20260713-0735.html",
      "destination": "/release-20260713-0750",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0"
        },
        {
          "key": "CDN-Cache-Control",
          "value": "no-store"
        },
        {
          "key": "Vercel-CDN-Cache-Control",
          "value": "no-store"
        },
        {
          "key": "Surrogate-Control",
          "value": "no-store"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        },
        {
          "key": "Clear-Site-Data",
          "value": "\"cache\""
        },
        {
          "key": "X-Thailuck-Release",
          "value": "20260713-0750"
        }
      ]
    }
  ]
}
